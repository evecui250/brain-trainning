generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GameSession {
  id        Int      @id @default(autoincrement())
  date      String
  gameType  String
  gameName  String
  completed Boolean  @default(false)
  score     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("game_sessions")
}

model QuizResult {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  score     Int
  total     Int      @default(5)
  answers   String   @default("{}")
  createdAt DateTime @default(now())

  @@map("quiz_results")
}

model DailyProgress {
  id             Int      @id @default(autoincrement())
  date           String   @unique
  gamesCompleted Int      @default(0)
  goalReached    Boolean  @default(false)
  quizDone       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("daily_progress")
}
